#!/bin/bash
# script para automatizar mantenimiento aplicación de Greenbone

YELLOW='\033[1;33m'
RED='\033[1;31m'
NC='\033[0m'

DB_NAME="gvmd"
DB_USER="postgres"
DAYS="15"

# Permitir ejecutar opción directamente por parámetro (para cron)
if [ -n "$1" ]; then
    opcion="$1"
else
    clear
    cat << 'EOF'

  __________                           ___.                          ___________           .__ ___.                 
 /    _____/______   ____   ____   ____\_ |__   ____   ____   ____   \__    ___/___   ____ |  |\_ |__   _______  ___
/     \  __\_  __ \_/ __ \_/ __ \ /    \| __ \ /  _ \ /    \_/ __ \    |    | /  _ \ /  _ \|  | | __ \ /  _ \  \/  /
\      \_\  \  | \/\  ___/\  ___/|   |  \ \_\ (  <_> )   |  \  ___/    |    |(  <_> |  <_> )  |_| \_\ (  <_> >    < 
 \________  /__|    \___  >\___  >___|  /___  /\____/|___|  /\___  >   |____| \____/ \____/|____/___  /\____/__/\_ \
          \/            \/     \/     \/    \/            \/     \/                                 \/            \/
                                            Script de mantenimiento para Greenbone

En Greenbone/GVM la información se divide en dos capas (la db indexa el contenido de los feeds):
Feeds → scap-data/ (CVEs/OVAL/CPEs) | cert-data/ (alerts CERT) | plugins (NVTs / NASL scripts)
DB    → gvmd indexa hosts, vulns, tasks, targets, reports, permissions y results

EOF

echo -e "${YELLOW}====================================================================================================================${NC}"
echo -e "${YELLOW} Menu de mantenimiento GVM${NC}"
echo -e "${YELLOW}====================================================================================================================${NC}"
echo -e "${YELLOW}1) DELETE Modo mantenimiento automático (DELETE feeds físicos, reports y DB > ${DAYS} días)${NC}"
echo -e "${YELLOW}2) Sincronizar feeds y reconstruir base de datos (greenbone-feed-sync + gvmd --rebuild)${NC}"
echo -e "${YELLOW}3) Optimizar base de datos (VACUUM FULL)${NC}"
echo -e "${YELLOW}4) Reiniciar servicios y sincronizadores (postgresql, gvmd, gsad, ospd-openvas, openvasd)${NC}"
echo -e "${YELLOW}5) Limpiar archivos físicos de feeds (/scap-data, /cert-data, /plugins)${NC}"
echo -e "${YELLOW}====================================================================================================================${NC}"
echo "Selecciona una opción: "

read -p "" opcion
fi

case $opcion in

1)
    echo "Modo mantenimiento automático..."

    systemctl stop gvmd ospd-openvas

    find /var/lib/gvm/scap-data /var/lib/gvm/cert-data /var/lib/openvas/plugins \
    -mtime +${DAYS} -exec rm -rf {} \;

    sudo -u $DB_USER psql -d $DB_NAME -c "
    DELETE FROM reports WHERE creation_time < EXTRACT(EPOCH FROM NOW() - INTERVAL '${DAYS} days');
    DELETE FROM results WHERE report NOT IN (SELECT id FROM reports);
    "

    systemctl start gvmd ospd-openvas
    ;;

2)
    echo -e "${YELLOW}Sincronizando feeds y reconstruyendo DB...${NC}"

    sudo runuser -u gvm -- greenbone-feed-sync --type all
    sudo runuser -u gvm -- gvmd --rebuild

    systemctl restart postgresql gvmd gsad ospd-openvas openvasd
    ;;

3)
    echo -e "${YELLOW}Optimizando base de datos...${NC}"

    sudo -u $DB_USER psql -d $DB_NAME -c "VACUUM FULL;"
    ;;

4)
    echo -e "${YELLOW}Reiniciando servicios...${NC}"

    systemctl restart postgresql gvmd gsad ospd-openvas openvasd
    ;;

5)
    echo -e "${YELLOW}Limpiando feeds físicos...${NC}"

    systemctl stop gvmd ospd-openvas

    rm -rf /var/lib/gvm/scap-data/*
    rm -rf /var/lib/gvm/cert-data/*
    rm -rf /var/lib/openvas/plugins/*

    systemctl start gvmd ospd-openvas
    systemctl restart gvmd
    ;;

*)
    echo -e "${RED}Opción inválida${NC}"
    ;;
esac
